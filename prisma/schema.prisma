generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Owner {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?  @unique
  createdAt DateTime @default(now())
  dogs      Dog[]
}

model Dog {
  id           String        @id @default(cuid())
  name         String
  breed        String
  birthDate    DateTime?
  notes        String?
  photo        String?
  ownerId      String
  createdAt    DateTime      @default(now())
  age          String?
  weight       String?
  appointments Appointment[]
  attendances  Attendance[]
  owner        Owner         @relation(fields: [ownerId], references: [id])
}

model Appointment {
  id                  String            @id @default(cuid())
  calComUid           String?           @unique
  date                DateTime
  status              AppointmentStatus @default(PENDING)
  serviceId           String
  dogId               String
  notes               String?
  createdAt           DateTime          @default(now())
  reminderSentAt      DateTime?
  todayReminderSentAt DateTime?
  dog                 Dog               @relation(fields: [dogId], references: [id])
  service             Service           @relation(fields: [serviceId], references: [id])
  review              Review?
}

model Attendance {
  id        String   @id @default(cuid())
  date      DateTime
  service   String
  notes     String?
  photos    String[]
  dogId     String
  createdAt DateTime @default(now())
  dog       Dog      @relation(fields: [dogId], references: [id])
}

model Service {
  id           String           @id @default(cuid())
  name         String
  price        Int
  duration     Int
  description  String?
  isActive     Boolean          @default(true)
  calComLink   String?          @map("cal_com_link")
  categoryId   String?
  order        Int              @default(0)
  appointments Appointment[]
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  services    Service[]
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id            String       @id @default(cuid())
  token         String       @unique @default(cuid())
  ownerName     String
  petName       String
  rating        Int          @default(0)
  text          String       @default("")
  status        ReviewStatus @default(PENDING)
  appointmentId String?      @unique
  createdAt     DateTime     @default(now())
  submittedAt   DateTime?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  photoUrl  String
  caption   String?
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  DONE
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
