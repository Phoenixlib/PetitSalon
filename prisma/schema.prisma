generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Owner {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?  @unique
  createdAt DateTime @default(now())
  dogs      Dog[]
}

model Dog {
  id           String        @id @default(cuid())
  name         String
  breed        String
  size         DogSize?
  age          String?
  weight       String?
  birthDate    DateTime?
  notes        String?
  photo        String?
  ownerId      String
  owner        Owner         @relation(fields: [ownerId], references: [id])
  appointments Appointment[]
  attendances  Attendance[]
  createdAt    DateTime      @default(now())
}

model Appointment {
  id        String            @id @default(cuid())
  calComUid String?           @unique // UID de la reserva en Cal.com
  date      DateTime
  status    AppointmentStatus @default(PENDING)
  serviceId String
  service   Service           @relation(fields: [serviceId], references: [id])
  dogId     String
  dog       Dog               @relation(fields: [dogId], references: [id])
  notes     String?
  review    Review?
  createdAt DateTime          @default(now())
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  DONE
  CANCELLED
}

enum DogSize {
  XS
  S
  M
  L
  XL
}

model Attendance {
  id        String   @id @default(cuid())
  date      DateTime
  service   String
  notes     String?
  photos    String[]
  dogId     String
  dog       Dog      @relation(fields: [dogId], references: [id])
  createdAt DateTime @default(now())
}

model Service {
  id           String           @id @default(cuid())
  name         String
  price        Int
  duration     Int
  description  String?
  isActive     Boolean          @default(true)
  order        Int              @default(0)
  calComLink   String?          @map("cal_com_link")
  categoryId   String?
  category     ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  appointments Appointment[]
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  services    Service[]
  createdAt   DateTime  @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

// Configuración global del sitio (clave-valor)
model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Preguntas frecuentes
model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id            String       @id @default(cuid())
  token         String       @unique @default(cuid())
  ownerName     String
  petName       String
  rating        Int          @default(0)  // 0 = aún no enviado por el cliente
  text          String       @default("")
  status        ReviewStatus @default(PENDING)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  submittedAt   DateTime?    // cuando el cliente envía el formulario
}

enum ReviewStatus {
  PENDING    // recibida o link enviado, pendiente de aprobación
  APPROVED   // visible en el landing
  REJECTED   // descartada
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  photoUrl  String                          // URL Cloudinary — foto del resultado
  caption   String?                         // Texto breve (ej: "Golden Retriever, corte de verano")
  order     Int      @default(0)            // Orden de aparición en el landing
  isVisible Boolean  @default(true)         // Si aparece en el landing
  createdAt DateTime @default(now())
}
